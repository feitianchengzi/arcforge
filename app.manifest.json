{
  "appId": "com.feitianchengzi.arcforge",
  "packageName": "arcforge",
  "productName": "ArcForge",
  "executableName": "arcforge",
  "version": "0.1.0",
  "description": "GitHub-first ArcForge workspace for indie developers and small teams.",
  "copyright": "Copyright © 2026 ArcForge contributors",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "bundle": {
    "outputDir": "release",
    "asar": true
  },
  "mac": {
    "category": "public.app-category.developer-tools",
    "targets": [
      "dmg"
    ]
  },
  "windows": {
    "targets": [
      "nsis"
    ]
  },
  "linux": {
    "category": "Development",
    "maintainer": "ArcForge Maintainers <hi@feitianchengzi.com>",
    "targets": [
      "AppImage"
    ]
  }
}
