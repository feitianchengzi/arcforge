{
  "name": "skillops",
  "version": "0.1.0",
  "description": "GitHub-first SkillOps workspace for indie developers and small teams.",
  "type": "module",
  "main": "dist/electron/main.js",
  "bin": {
    "skillops": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 dist/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "start": "electron .",
    "cli": "node dist/cli/index.js",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "agent-skills",
    "skillops",
    "electron",
    "react",
    "github-first",
    "claude-code",
    "codex",
    "cursor"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "electron": "^35.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.3"
  }
}
